# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_BOT_USERNAME=your_bot_username_here

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# YouTube Channel IDs (comma-separated, up to 100 channels)
# Example: UCHnyfMqiRRG1u-2MsSQLbXA,UCYO_jab_esuFRV4b17AJtAw
YOUTUBE_CHANNEL_IDS=channel_id_1,channel_id_2

# Scheduling Configuration
# Schedule start time in HH:MM format (24-hour, e.g., 06:30 for 6:30 AM)
# If not set, defaults to current time + 5 minutes after first run
# SCHEDULE_START_TIME=06:30

# How often to check for new videos (1-24 hours)
# Default: 6 hours
SCHEDULE_FREQUENCY_HOURS=6

# Optional: Database path (default: data/subscriptions_state.db)
# DATABASE_PATH=data/subscriptions_state.db

# Optional: Logging level (default: INFO)
# LOG_LEVEL=INFO